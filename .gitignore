# Ren'Py compiled bytecode (regenerated on every launch)
*.rpyc
*.rpymc
*.rpa

# Ren'Py runtime caches and per-user saves
game/cache/
game/saves/
game/__pycache__/

# Ren'Py / dev logs
log.txt
errors.txt
traceback.txt
renpy-launch.log

# Distribution build outputs
dist/
*.zip
*.7z

# Loading-screen "stills" mode placeholders — local-only throwaway art
# (e.g. copyrighted GTA screenshots used for the POC). Real loading-screen
# art should be original; see the loading-screens ticket. Parallax mode uses
# in-repo sprites/bgs and needs nothing here.
game/images/loadscreens/

# OS junk
.DS_Store
Thumbs.db

# Editor junk
.vscode/
.idea/
*.swp
